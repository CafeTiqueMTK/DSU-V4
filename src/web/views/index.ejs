<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DSU-V4 | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <div class="container">
            <a href="/" class="logo">DSU-V4</a>
            <div class="nav-links">
                <a href="/">Accueil</a>
                <a href="/guilds">Serveurs</a>
                <a href="/logout" class="logout-link">Déconnexion</a>
            </div>
        </div>
    </nav>

    <main class="container">
        <header>
            <h1 class="section-title">Tableau de bord</h1>
            <p class="section-subtitle">Connecté en tant que <strong><%= bot.user.tag %></strong></p>
        </header>

        <section class="grid-stats">
            <div class="card">
                <p class="card-label">Statut</p>
                <div class="status-indicator <%= bot.readyAt ? 'status-online' : 'status-offline' %>">
                    <%= bot.readyAt ? 'En ligne' : 'Hors ligne' %>
                </div>
            </div>
            <div class="card">
                <p class="card-label">Serveurs</p>
                <div class="stat-value"><%= bot.guilds.cache.size %></div>
            </div>
            <div class="card">
                <p class="card-label">Utilisateurs</p>
                <div class="stat-value"><%= bot.users.cache.size %></div>
            </div>
            <div class="card">
                <p class="card-label">Commandes</p>
                <div class="stat-value"><%= bot.commands.size %></div>
            </div>
        </section>

        <section>
            <h2 class="form-section-title">Actions rapides</h2>
            <div class="grid-stats"> <!-- Utilise grid-stats pour aligner parfaitement les colonnes -->
                <a href="/guilds" class="card card-link">
                    <p class="card-label">Management</p>
                    <h3 class="card-title">Gérer les serveurs</h3>
                    <p class="card-text">Configurez l'automod, les logs et plus encore.</p>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
